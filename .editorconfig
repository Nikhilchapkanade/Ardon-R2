# EditorConfig — keeps whitespace consistent across editors and contributors.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown — trailing spaces can be meaningful (line breaks)
[*.md]
trim_trailing_whitespace = false

# TOML, YAML, JSON — 2-space convention
[*.{toml,yml,yaml,json}]
indent_size = 2

# Makefile actually requires tabs
[Makefile]
indent_style = tab
